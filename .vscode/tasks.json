{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "Build MazeCraze",
            "command": "g++",
            "args": [
                "-std=c++17",
                "-fdiagnostics-color=always",
                "-g",
                "src/GUI/window.cpp",
                "src/Code/Graph/Graph.cpp",
                "src/Code/MazeGenerator/MazeGenerator.cpp",
                "src/Code/Path/Path.cpp",
                "src/Code/Player/Player.cpp",
                "src/Code/Game/Game.cpp",
                "-lsfml-graphics",
                "-lsfml-window",
                "-lsfml-system",
                "-o",
                "MazeCraze"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}