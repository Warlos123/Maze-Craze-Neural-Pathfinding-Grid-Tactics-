{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build MazeCraze",
            "type": "shell",
            "command": "g++",
            "args": [
                "-std=c++17",

                "window.cpp",

                "PlayerVSIA/PlayerVSIA.cpp",
                "Multiplayer/Multiplayer.cpp",

                "-I.",

                "-o",
                "app",

                "-lsfml-graphics",
                "-lsfml-window",
                "-lsfml-system"
            ],

            "options": {
                "cwd": "${workspaceFolder}/src/GUI"
            },

            "group": {
                "kind": "build",
                "isDefault": true
            },

            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}